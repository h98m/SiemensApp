<UserControl x:Class="SiemensApp.Views.DebtsThemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             Background="#F8FAFC" FlowDirection="RightToLeft"
             FontFamily="Segoe UI Semibold">

    <UserControl.Resources>
        <Style x:Key="SearchField" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="12" Background="{TemplateBinding Background}" 
                                BorderBrush="#E2E8F0" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
                            <Grid Margin="15,0">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="35">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Grid Width="300" Margin="0,0,15,0">
                    <TextBox Style="{StaticResource SearchField}" Height="48" x:Name="txtSearchDebt" TextChanged="txtSearchDebt_TextChanged" />
                    <TextBlock Text="🔍 بحث في أسماء الدائنين..." HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0" Foreground="#94A3B8" IsHitTestVisible="False"/>
                </Grid>
                <Button Click="ShowAddDebt_Click" Height="48" Padding="20,0" Background="#2563EB" Foreground="White">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="12"/>
                        </Style>
                    </Button.Resources>
                    <TextBlock Text="+ إضافة دائن جديد" VerticalAlignment="Center" FontWeight="Bold"/>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="20">
            <DataGrid x:Name="dgvDebts" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="None" 
                      HeadersVisibility="Column" Background="Transparent" BorderThickness="0" RowHeight="65" 
                      AlternatingRowBackground="#F8FAFC" FontSize="14"
					  MouseLeftButtonUp="dgvDebts_MouseLeftButtonUp">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="15,12"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
				<DataGrid.Columns>
					<DataGridTemplateColumn Header="قائمة الدائنين (اضغط للاستمرار)" Width="*">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate>
								<Grid Background="Transparent" Cursor="Hand">
									<StackPanel Orientation="Horizontal" Margin="15,0">
										<Border Width="40" Height="40" CornerRadius="12" Background="#EFF6FF">
											<TextBlock Text="🏛️" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
										</Border>
										<StackPanel Margin="12,0" VerticalAlignment="Center">
											<TextBlock Text="{Binding DebtorName}" FontWeight="Bold" Foreground="#1E293B" FontSize="14"/>
											<TextBlock Text="{Binding PhoneNumber}" Foreground="#64748B" FontSize="11" Margin="0,2,0,0"/>
										</StackPanel>
									</StackPanel>
								</Grid>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>
				</DataGrid.Columns>
            </DataGrid>
        </Border>

		<Grid x:Name="AddDebtCard" Grid.RowSpan="3" Visibility="Collapsed">
			<!-- خلفية شبه شفافة مع تأثير ضبابي إذا كان مدعوماً أو تعتيم متدرج -->
			<Grid.Background>
				<SolidColorBrush Color="#020617" Opacity="0.6"/>
			</Grid.Background>

			<Border Background="White"
					CornerRadius="20"
					Width="480"
					VerticalAlignment="Center"
					Padding="30"
					BorderBrush="#E2E8F0"
					BorderThickness="1">
				<Border.Effect>
					<DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.1" Color="Black"/>
				</Border.Effect>

				<StackPanel>
					<!-- العنوان -->
					<TextBlock Text="إضافة دين جديد"
							   FontSize="24"
							   FontWeight="ExtraBold"
							   Foreground="#1E293B"
							   Margin="0,0,0,5"/>
					<TextBlock Text="أدخل تفاصيل الدائن والمبلغ بدقة"
							   FontSize="13"
							   Foreground="#64748B"
							   Margin="0,0,0,25"/>

					<Separator Background="#F1F5F9" Margin="0,0,0,25"/>

					<!-- اسم الدائن -->
					<TextBlock Text="اسم الدائن أو الشركة" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#475569"/>
					<TextBox Style="{StaticResource SearchField}"
							 Height="48"
							 x:Name="txtDebtorName"
							 Tag="مثال: شركة الهدى التجارية..."
							 Margin="0,0,0,20"
							 VerticalContentAlignment="Center"
							 Padding="15,0"/>

					<Grid Margin="0,0,0,20">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<!-- رقم الهاتف -->
						<StackPanel Grid.Column="0" Margin="0,0,10,0">
							<TextBlock Text="رقم الهاتف" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#475569"/>
							<TextBox Style="{StaticResource SearchField}"
									 Height="48"
									 x:Name="txtPhoneNumber"
									 VerticalContentAlignment="Center"
									 Padding="15,0"/>
						</StackPanel>

						<!-- المبلغ والعملة -->
						<StackPanel Grid.Column="1" Margin="10,0,0,0">
							<TextBlock Text="المبلغ المطلوب" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#475569"/>
							<Grid>
								<TextBox Style="{StaticResource SearchField}"
										 Height="48"
										 x:Name="txtInitialAmount"
										 Padding="10,0,85,0"
										 VerticalContentAlignment="Center"
										 TextChanged="txtInitialAmount_TextChanged"/>

								<!-- محول العملات بتصميم احترافي -->
								<Border Background="#F8FAFC"
										CornerRadius="8"
										HorizontalAlignment="Right"
										Margin="4"
										BorderBrush="#E2E8F0"
										BorderThickness="1">
									<StackPanel Orientation="Horizontal">
										<Button x:Name="btnCurrencyIQD" Content="د.ع" Click="Currency_Click" Tag="IQD"
												Width="35" Height="32" Background="#2563EB" Foreground="White" BorderThickness="0">
											<Button.Resources>
												<Style TargetType="Border">
													<Setter Property="CornerRadius" Value="6,0,0,6"/>
												</Style>
											</Button.Resources>
										</Button>
										<Button x:Name="btnCurrencyUSD" Content="$" Click="Currency_Click" Tag="USD"
												Width="35" Height="32" Background="Transparent" Foreground="#64748B" BorderThickness="0">
											<Button.Resources>
												<Style TargetType="Border">
													<Setter Property="CornerRadius" Value="0,6,6,0"/>
												</Style>
											</Button.Resources>
										</Button>
									</StackPanel>
								</Border>
							</Grid>
						</StackPanel>
					</Grid>

					<!-- تفقيط المبلغ -->
					<Border Background="#EFF6FF" CornerRadius="8" Padding="12,8" Margin="0,0,0,20">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="✍️" Margin="0,0,8,0" VerticalAlignment="Center"/>
							<TextBlock x:Name="lblAmountWord"
									   Text="المبلغ كتابةً: صفر دينار عراقي"
									   FontSize="13"
									   FontWeight="Medium"
									   Foreground="#1D4ED8"
									   TextWrapping="Wrap"/>
						</StackPanel>
					</Border>

					<!-- الملاحظات -->
					<TextBlock Text="ملاحظات إضافية" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#475569"/>
					<TextBox Style="{StaticResource SearchField}"
							 Height="100"
							 x:Name="txtDebtNote"
							 TextWrapping="Wrap"
							 AcceptsReturn="True"
							 Padding="15,10"
							 VerticalContentAlignment="Top"/>

					<!-- أزرار التحكم -->
					<Button Click="SaveDebt_Click"
							Content="حفظ البيانات"
							Background="#2563EB"
							Foreground="White"
							Height="54"
							Margin="0,25,0,10"
							FontSize="16"
							FontWeight="Bold"
							Cursor="Hand">
						<Button.Resources>
							<Style TargetType="Border">
								<Setter Property="CornerRadius" Value="12"/>
							</Style>
						</Button.Resources>
					</Button>

					<Button Click="HideAddDebt_Click"
							Content="إلغاء العملية"
							Background="Transparent"
							Foreground="#94A3B8"
							Height="40"
							BorderThickness="0"
							Cursor="Hand"/>
				</StackPanel>
			</Border>
		</Grid>

        <Grid x:Name="PayDebtCard" Grid.RowSpan="3" Visibility="Collapsed">
            <Grid.Background>
                <SolidColorBrush Color="#0F172A" Opacity="0.6"/>
            </Grid.Background>
            <Border Background="White" CornerRadius="24" Width="420" Padding="30" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="💸 دفع مبلغ للدائن" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                    <Border Background="#F1F5F9" CornerRadius="12" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock x:Name="txtPayTargetName" Text="اسم الدائن: ..." FontSize="14" Foreground="#64748B"/>
                            <TextBlock x:Name="txtPayCurrentDebt" Text="المبلغ المطلوب منا: 0" FontSize="18" FontWeight="Bold" Foreground="#2563EB" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="المبلغ المراد دفعهُ لهُ" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtPayAmountInput" Height="50" Padding="15,0" FontSize="20" FontWeight="Bold" VerticalContentAlignment="Center"/>
                    <Grid Margin="0,30,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Content="تأكيد الدفع" Click="ConfirmPay_Click" Height="50" Background="#059669" Foreground="White" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="إلغاء" Click="ClosePayCard_Click" Background="#F1F5F9" Foreground="#64748B" Height="50" Margin="5,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>