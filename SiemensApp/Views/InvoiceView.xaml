<UserControl x:Class="SiemensApp.Views.InvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F3F7" FlowDirection="RightToLeft">
	<UserControl.Resources>
		<!-- ستايل البطاقات الخرافي للخيارات -->
		<Style x:Key="ModernSettingCard" TargetType="CheckBox">
			<Setter Property="Background" Value="#FFFFFF"/>
			<Setter Property="BorderBrush" Value="#F1F5F9"/>
			<Setter Property="Height" Value="70"/>
			<Setter Property="Margin" Value="0,5,0,5"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="CheckBox">
						<Border x:Name="MainBorder"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="1"
								CornerRadius="15"
								SnapsToDevicePixels="True">
							<Border.Effect>
								<DropShadowEffect BlurRadius="10" Opacity="0.02" ShadowDepth="1"/>
							</Border.Effect>

							<Grid Margin="15,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>

								<StackPanel VerticalAlignment="Center">
									<ContentPresenter TextBlock.FontSize="15" TextBlock.FontWeight="SemiBold" TextBlock.Foreground="#334155"/>
								</StackPanel>

								<!-- السويتش (Switch) المطور -->
								<Border x:Name="SwitchTrack" Grid.Column="1" Width="44" Height="22" CornerRadius="11" Background="#E2E8F0" VerticalAlignment="Center">
									<Ellipse x:Name="SwitchThumb" Width="16" Height="16" Fill="White" HorizontalAlignment="Left" Margin="3,0">
										<Ellipse.RenderTransform>
											<TranslateTransform X="0"/>
										</Ellipse.RenderTransform>
									</Ellipse>
								</Border>
							</Grid>
						</Border>

						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="MainBorder" Property="BorderBrush" Value="#3B82F6"/>
								<Setter TargetName="MainBorder" Property="Background" Value="#F8FAFC"/>
							</Trigger>
							<Trigger Property="IsChecked" Value="True">
								<Setter TargetName="SwitchTrack" Property="Background" Value="#10B981"/>
								<Trigger.EnterActions>
									<BeginStoryboard>
										<Storyboard>
											<DoubleAnimation Storyboard.TargetName="SwitchThumb"
															 Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
															 To="22" Duration="0:0:0.2"/>
										</Storyboard>
									</BeginStoryboard>
								</Trigger.EnterActions>
								<Trigger.ExitActions>
									<BeginStoryboard>
										<Storyboard>
											<DoubleAnimation Storyboard.TargetName="SwitchThumb"
															 Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
															 To="0" Duration="0:0:0.2"/>
										</Storyboard>
									</BeginStoryboard>
								</Trigger.ExitActions>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- أنيميشن ظهور اللوحة -->
		<Storyboard x:Key="OpenSettingsAnim">
			<DoubleAnimation Storyboard.TargetName="SettingsPaneTransform"
							 Storyboard.TargetProperty="X"
							 From="320" To="0" Duration="0:0:0.4">
				<DoubleAnimation.EasingFunction>
					<CubicEase EasingMode="EaseOut"/>
				</DoubleAnimation.EasingFunction>
			</DoubleAnimation>
			<DoubleAnimation Storyboard.TargetName="SettingsPane"
							 Storyboard.TargetProperty="Opacity"
							 From="0" To="1" Duration="0:0:0.2"/>
		</Storyboard>
	</UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,15" Background="White" CornerRadius="15" Padding="20,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2" Color="#002060"/>
            </Border.Effect>

            <Grid>
                <Grid.Resources>
                    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

                    <Style TargetType="TextBox">
                        <Setter Property="Height" Value="45"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Border x:Name="border" CornerRadius="10" BorderThickness="{TemplateBinding BorderThickness}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" Background="{TemplateBinding Background}">
                                        <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                                            <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

				<StackPanel Grid.Row="0" Grid.Column="0">
					<TextBlock Text="👤 اسم الزبون" FontSize="13" Foreground="#64748B" Margin="5,0,0,8"/>
					<Grid>
						<TextBox x:Name="txtCustomerName"
								 TextChanged="txtCustomerName_TextChanged"
								 KeyDown="txtCustomerName_KeyDown"
								 Padding="8"
								 FontSize="14"/>

						<!-- التعديل هنا: جعل القائمة منبثقة بشكل احترافي -->
						<Popup x:Name="popCustomerSearch"
							   PlacementTarget="{Binding ElementName=txtCustomerName}"
							   StaysOpen="False"
							   AllowsTransparency="True"
							   PopupAnimation="Slide"
							   Placement="Bottom"
							   VerticalOffset="5">
							<Border Background="White"
									BorderBrush="#E2E8F0"
									BorderThickness="1"
									CornerRadius="12"
									Width="{Binding ElementName=txtCustomerName, Path=ActualWidth}"
									MinWidth="250">
								<Border.Effect>
									<DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="2" Direction="270"/>
								</Border.Effect>

								<ListBox x:Name="lstCustomerSuggestions"
										 DisplayMemberPath="DebtorName"
										 MaxHeight="250"
										 BorderThickness="0"
										 Background="Transparent"
										 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
										 MouseDoubleClick="lstCustomerSuggestions_MouseDoubleClick">
									<ListBox.ItemContainerStyle>
										<Style TargetType="ListBoxItem">
											<Setter Property="Padding" Value="12,10"/>
											<Setter Property="Margin" Value="2"/>
											<Setter Property="Template">
												<Setter.Value>
													<ControlTemplate TargetType="ListBoxItem">
														<Border x:Name="ItemBorder"
																Background="Transparent"
																CornerRadius="8">
															<ContentPresenter Margin="{TemplateBinding Padding}"/>
														</Border>
														<ControlTemplate.Triggers>
															<Trigger Property="IsMouseOver" Value="True">
																<Setter TargetName="ItemBorder" Property="Background" Value="#F1F5F9"/>
															</Trigger>
															<Trigger Property="IsSelected" Value="True">
																<Setter TargetName="ItemBorder" Property="Background" Value="#1E40AF"/>
																<Setter Property="Foreground" Value="White"/>
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Setter.Value>
											</Setter>
										</Style>
									</ListBox.ItemContainerStyle>
								</ListBox>
							</Border>
						</Popup>
					</Grid>
				</StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Text="📞 رقم الهاتف" FontSize="13" Foreground="#64748B" Margin="5,0,0,5"/>
                    <TextBox x:Name="txtCustomerPhone"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="4">
                    <TextBlock Text="📍 العنوان الكامل" FontSize="13" Foreground="#64748B" Margin="5,0,0,5"/>
                    <TextBox x:Name="txtCustomerAddress"/>
                </StackPanel>

				<StackPanel Grid.Row="0" Grid.Column="6" VerticalAlignment="Bottom">
					<TextBlock Text="💳 الحالة" FontSize="13" Foreground="#64748B" Margin="5,0,0,5"/>
					<CheckBox x:Name="btnPaymentStatus" Checked="UpdateGrandTotal_Event" Unchecked="UpdateGrandTotal_Event">
						<CheckBox.Template>
							<ControlTemplate TargetType="CheckBox">
								<Border x:Name="btnBorder" Background="#DCFCE7" Width="120" Height="45" CornerRadius="10" Cursor="Hand">
									<TextBlock x:Name="txtStatus" Text="💵 نقدي" FontWeight="Bold" Foreground="#15803D" HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>

								<ControlTemplate.Triggers>
									<Trigger Property="IsChecked" Value="True">
										<Setter TargetName="btnBorder" Property="Background" Value="#FEE2E2"/>
										<Setter TargetName="txtStatus" Property="Text" Value="⏳ آجل"/>
										<Setter TargetName="txtStatus" Property="Foreground" Value="#B91C1C"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</CheckBox.Template>
					</CheckBox>
				</StackPanel>

                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text=" صرف )" FontSize="12" Foreground="#64748B" Margin="5,0,0,5"/>
                        <TextBox x:Name="txtDollarRate" Text="145" Background="#F0F9FF" FontWeight="Bold" 
             Foreground="#1E40AF" TextChanged="UpdateGrandTotal_Event" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Visibility="{Binding IsChecked, ElementName=btnPaymentStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text=" ديون سابقة " FontSize="12" Foreground="#64748B" Margin="5,0,0,5"/>
                        <TextBox x:Name="txtDebtDollar" Text="0" Foreground="#B91C1C" 
             TextChanged="UpdateGrandTotal_Event" />
                    </StackPanel>


                    <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                        <TextBlock Text="📄 نوع الوصل" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="5,0,0,5"/>
                        <Button x:Name="btnInvoiceType" Click="btnInvoiceType_Click" Width="120" Height="45" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btnBorder" Background="#F1F5F9" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter x:Name="content" Margin="10,0" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0"/>
                                            <TextBlock Text="▾" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,2" Foreground="#64748B"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnBorder" Property="Background" Value="#E2E8F0"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding Content, ElementName=btnInvoiceType}" Value="وصل وهمي 1 ▾">
                                            <Setter TargetName="btnBorder" Property="Background" Value="#FFF1F2"/>
                                            <Setter TargetName="btnBorder" Property="BorderBrush" Value="#FECDD3"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Content, ElementName=btnInvoiceType}" Value="وصل وهمي 2 ▾">
                                            <Setter TargetName="btnBorder" Property="Background" Value="#FFF1F2"/>
                                            <Setter TargetName="btnBorder" Property="BorderBrush" Value="#FECDD3"/>
                                        </DataTrigger>
										<DataTrigger Binding="{Binding Content, ElementName=btnInvoiceType}" Value="وصل وهمي 3 ▾">
											<Setter TargetName="btnBorder" Property="Background" Value="#FFF1F2"/>
											<Setter TargetName="btnBorder" Property="BorderBrush" Value="#FECDD3"/>
										</DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>

							<Button.ContextMenu>
								<ContextMenu x:Name="cmInvoiceTypes" BorderThickness="0" Background="Transparent">
									<ContextMenu.Resources>
										<!-- 1. ستايل الحاوية الخارجية (القائمة نفسها) -->
										<Style TargetType="ContextMenu">
											<Setter Property="Template">
												<Setter.Value>
													<ControlTemplate TargetType="ContextMenu">
														<Border Background="White"
																CornerRadius="14"
																BorderBrush="#E2E8F0"
																BorderThickness="1"
																Padding="6">
															<Border.Effect>
																<!-- ظل ناعم يعطي عمق واحترافية -->
																<DropShadowEffect BlurRadius="20" Opacity="0.15" ShadowDepth="3" Direction="270"/>
															</Border.Effect>
															<StackPanel IsItemsHost="True" RenderOptions.ClearTypeHint="Enabled"/>
														</Border>
													</ControlTemplate>
												</Setter.Value>
											</Setter>
										</Style>

										<!-- 2. ستايل العناصر (الخيارات) - الغاء الشريط الرمادي -->
										<Style TargetType="MenuItem">
											<Setter Property="Foreground" Value="#334155"/>
											<Setter Property="FontSize" Value="14"/>
											<Setter Property="FontWeight" Value="Medium"/>
											<Setter Property="Padding" Value="12,10"/>
											<Setter Property="Template">
												<Setter.Value>
													<ControlTemplate TargetType="MenuItem">
														<Border x:Name="ItemBorder"
																Background="Transparent"
																CornerRadius="8"
																Margin="2">
															<Grid>
																<ContentPresenter ContentSource="Header"
																				  Margin="{TemplateBinding Padding}"
																				  HorizontalAlignment="Right"
																				  VerticalAlignment="Center"/>
															</Grid>
														</Border>
														<ControlTemplate.Triggers>
															<!-- تأثير عند تمرير الماوس -->
															<Trigger Property="IsMouseOver" Value="True">
																<Setter TargetName="ItemBorder" Property="Background" Value="#F1F5F9"/>
																<Setter Property="Foreground" Value="#0F172A"/>
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Setter.Value>
											</Setter>
										</Style>

										<!-- 3. ستايل الخط الفاصل -->
										<Style TargetType="Separator">
											<Setter Property="Background" Value="#F1F5F9"/>
											<Setter Property="Height" Value="1"/>
											<Setter Property="Margin" Value="10,5"/>
										</Style>
									</ContextMenu.Resources>

									<!-- العناصر داخل القائمة -->
									<MenuItem Header="🏠 وصل المحل" Click="InvoiceType_Selected" FontWeight="Bold" Foreground="#1E293B"/>
									<Separator/>
									<MenuItem Header="وصل محل اجراس" Click="InvoiceType_Selected" Foreground="#E11D48"/>
									<MenuItem Header="وصل محل عصام" Click="InvoiceType_Selected" Foreground="#E11D48"/>
									<MenuItem Header="وصل محل لمسة التكنولوجيا" Click="InvoiceType_Selected" Foreground="#E11D48"/>
									<MenuItem Header="وصل محل المعين" Click="InvoiceType_Selected" Foreground="#E11D48"/>
								</ContextMenu>
							</Button.ContextMenu>

                            <Button.Content>
                                <TextBlock x:Name="txtCurrentType" Text="وصل المحل" FontWeight="Bold" Foreground="#1E293B"/>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
        <Border Grid.Row="1" Margin="0,0,0,15" Background="White" CornerRadius="15" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.03" ShadowDepth="1"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <StackPanel Margin="5,0">
                        <TextBlock Text="التفاصيل (المادة)" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="5,0,0,3"/>
                        <Grid>
                            <TextBox x:Name="txtInputProduct" Width="300" Height="40" VerticalContentAlignment="Center" Padding="10,0" TextChanged="txtInputProduct_TextChanged" KeyDown="txtInputProduct_KeyDown">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            <Popup x:Name="popSearch" PlacementTarget="{Binding ElementName=txtInputProduct}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" Width="{Binding ElementName=txtInputProduct, Path=ActualWidth}">
                                <Border Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="#E2E8F0">
                                    <ListBox x:Name="lstSearchSuggestions" MaxHeight="250" BorderThickness="0" Background="Transparent" MouseDoubleClick="lstSearchSuggestions_MouseDoubleClick" KeyDown="lstSearchSuggestions_KeyDown">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="5,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Price, StringFormat={}{0:N0}}" Foreground="#3B82F6" Margin="10,0"/>
                                                    <TextBlock Text="{Binding ProductName}" Grid.Column="1" TextAlignment="Right" FontWeight="SemiBold"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="5,0">
                        <TextBlock Text="العدد" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="5,0,0,3"/>
                        <TextBox x:Name="txtInputQty" Width="70" Height="40" Text="1" VerticalContentAlignment="Center" TextAlignment="Center">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Margin="5,0">
                        <TextBlock Text="النوع" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="5,0,0,3"/>
                        <TextBox x:Name="txtInputType" Width="90" Height="40" Text="قطعة" VerticalContentAlignment="Center" Padding="10,0">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Margin="5,0">
                        <TextBlock Text="السعر" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="5,0,0,3"/>
                        <TextBox x:Name="txtInputPrice" Width="160" Height="40" VerticalContentAlignment="Center" Padding="10,0" TextChanged="txtInputPrice_TextChanged">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Margin="5,0">
                        <TextBlock Text="العملة" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="5,0,0,3"/>
                        <ToggleButton x:Name="btnCurrencyToggle" Width="120" Height="40" Checked="Currency_Changed" Unchecked="Currency_Changed" Cursor="Hand" Background="White">
                            <ToggleButton.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </ToggleButton.Resources>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtCurrencyFlag" Text="🇮🇶" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtCurrencyName" Text="د.عراقي" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>

                    <Button Click="btnAddRow_Click" Content="" FontFamily="Segoe MDL2 Assets" FontSize="18" Width="50" Height="40" Margin="5,18,0,0" Background="#006400" Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,8,0,0">
                    <TextBlock Text="فقط: " FontSize="12" Foreground="#64748B" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="lblPriceInWords" 
               FontSize="14" 
               FontWeight="Bold" 
               Foreground="#059669" 
               VerticalAlignment="Center"
               Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>


        <Border Grid.Row="2" Background="White" CornerRadius="15" ClipToBounds="True">
            <DataGrid x:Name="dgvInvoiceItems" AutoGenerateColumns="False" IsReadOnly="True" 
          BorderThickness="0" Background="Transparent" RowHeight="50" FontSize="14"
          GridLinesVisibility="None"  SelectionMode="Single" CanUserResizeColumns="False" CanUserReorderColumns="False"
          HeadersVisibility="Column" HorizontalScrollBarVisibility="Auto">

                <DataGrid.Resources>
                    <Style TargetType="DataGridCell">
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style TargetType="TextBlock" x:Key="CenterTextStyle">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="التفاصيل" Binding="{Binding ProductName}" Width="2*" ElementStyle="{StaticResource CenterTextStyle}"/>
                    <DataGridTextColumn Header="العدد" Binding="{Binding Qty, StringFormat='{}{0:G29}'}" Width="*" ElementStyle="{StaticResource CenterTextStyle}"/>
                    <DataGridTextColumn Header="النوع" Binding="{Binding Type}" Width="*" ElementStyle="{StaticResource CenterTextStyle}"/>

                    <DataGridTextColumn Header="السعر" Binding="{Binding Price, StringFormat='{}{0:#,#.##}'}" Width="*" ElementStyle="{StaticResource CenterTextStyle}"/>

                    <DataGridTextColumn Header="الإجمالي" Binding="{Binding Total, StringFormat='{}{0:#,#.##}'}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#006400"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="تعديل" Foreground="#4F46E5" Background="Transparent" 
                        BorderThickness="0" FontWeight="Bold" FontSize="12" 
                        Margin="5,0" Click="BtnEditItem_Click" Cursor="Hand"/>

                                    <Button Content="حذف" Foreground="#EF4444" Background="Transparent" 
                        BorderThickness="0" FontSize="12" FontWeight="Bold" 
                        Margin="5,0" Click="BtnRemoveItem_Click" Cursor="Hand"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Border Background="#E9F5E9" CornerRadius="12" HorizontalAlignment="Left" Padding="20,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="المبلغ الإجمالي:" FontSize="14" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="#64748B"/>
                    <TextBlock x:Name="lblTotal" Text="0" FontSize="24" FontWeight="Black" Foreground="#047857"/>
                    <TextBlock Text="د.ع" Margin="5,0,20,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblTotalDollar" Text="0.00" FontSize="24" FontWeight="Black" Foreground="#15803D"/>
                    <TextBlock Text="$" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
               
                <Button Click="btnOpenSettings_Click" Width="220" Height="50" Background="#1E293B" Foreground="White" FontSize="16" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="12"/>
                        </Style>
                    </Button.Resources>
                    <Button.Content>
                        <TextBlock Text="الإعدادات" />
                    </Button.Content>
                </Button>
                <Button Click="BtnSaveInvoice_Click" Width="220" Height="50" Background="#1E293B" Foreground="White" FontSize="16" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="12"/>
                        </Style>
                    </Button.Resources>
                    <Button.Content>
                        <TextBlock Text="حفظ وطباعة الفاتورة"/>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>
		<Border x:Name="SettingsPane" Grid.Row="0" Grid.RowSpan="4" Panel.ZIndex="1000"
        HorizontalAlignment="Right" Width="320" Background="#F8FAFC" Visibility="Collapsed" Opacity="0">
			<Border.RenderTransform>
				<TranslateTransform x:Name="SettingsPaneTransform" X="320"/>
			</Border.RenderTransform>
			<Border.Effect>
				<DropShadowEffect BlurRadius="40" Opacity="0.15" ShadowDepth="0" Color="#0F172A"/>
			</Border.Effect>

			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<!-- Header -->
					<RowDefinition Height="*"/>
					<!-- Content -->
					<RowDefinition Height="Auto"/>
					<!-- Footer -->
				</Grid.RowDefinitions>

				<!-- الهيدر الفخم -->
				<Border Grid.Row="0" Background="White" Padding="25,30,25,20" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
					<Grid>
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
							<TextBlock Text="تخصيص الطباعة" FontSize="22" FontWeight="Black" Foreground="#1E293B"/>
							<TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#64748B" Margin="12,5,0,0"/>
						</StackPanel>
						<Button HorizontalAlignment="Left" VerticalAlignment="Center" Background="#F1F5F9" BorderThickness="0"
								Width="35" Height="35" Cursor="Hand" Click="btnCloseSettings_Click">
							<Button.Resources>
								<Style TargetType="Border">
									<Setter Property="CornerRadius" Value="10"/>
								</Style>
							</Button.Resources>
							<TextBlock Text="&#xE106;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="14"/>
						</Button>
					</Grid>
				</Border>

				<!-- المحتوى -->
				<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Padding="20">
					<StackPanel>
						<!-- حذفنا خاصية التباعد نهائياً حجي حتى نخلص من الخطأ -->
						<TextBlock Text="أنماط الفواتير" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" Margin="10,0,0,10"/>

						<CheckBox x:Name="chkDefaultMode" Content="🚀 الوضع الكامل" Style="{StaticResource ModernSettingCard}"
								  IsChecked="True" Checked="chkDefaultMode_Checked"/>

						<CheckBox x:Name="chkShowDollar" Content="💵 دولار فقط" Style="{StaticResource ModernSettingCard}"
								  Checked="chkShowDollar_Checked"/>

						<CheckBox x:Name="chkShowDinar" Content="🇮🇶 دينار فقط" Style="{StaticResource ModernSettingCard}"
								  Checked="chkShowDinar_Checked"/>

						<Separator Background="#F1F5F9" Margin="0,15"/>

						<TextBlock Text="خيارات العرض" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" Margin="10,0,0,10"/>

						<CheckBox x:Name="chkHidePreviousDebt" Content="🙈 إخفاء الدين السابق" Style="{StaticResource ModernSettingCard}"
								  Checked="Option_Checked"/>

						<CheckBox x:Name="chkHideWriting" Content="✍️ إخفاء التفقيط" Style="{StaticResource ModernSettingCard}"
								  Checked="Option_Checked"/>
					</StackPanel>
				</ScrollViewer>

				<!-- فوتر اللوحة -->
				<Border Grid.Row="2" Padding="20" Background="#F1F5F9">
					<TextBlock Text="سيمنز برو • إعدادات المستخدم" HorizontalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"/>
				</Border>
			</Grid>
		</Border>
    </Grid>
</UserControl>