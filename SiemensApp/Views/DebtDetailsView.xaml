<UserControl x:Class="SiemensApp.Views.DebtDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9" FlowDirection="RightToLeft">

	<UserControl.Resources>
		<Style TargetType="DataGridColumnHeader" x:Key="UnifiedHeaderStyle">
			<Setter Property="Background" Value="#F8FAFC"/>
			<Setter Property="Foreground" Value="#64748B"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Height" Value="45"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="BorderThickness" Value="0,0,0,1"/>
			<Setter Property="BorderBrush" Value="#E2E8F0"/>
		</Style>

		<Style TargetType="TextBlock" x:Key="CenterTextStyle">
			<Setter Property="HorizontalAlignment" Value="Center"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="TextAlignment" Value="Center"/>
		</Style>

		<Style TargetType="DataGridCell">
			<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Style.Triggers>
				<Trigger Property="IsSelected" Value="True">
					<Setter Property="Background" Value="Transparent"/>
					<Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=Foreground}"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style TargetType="DataGridRow">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Style.Triggers>
				<Trigger Property="IsSelected" Value="True">
					<Setter Property="Background" Value="#F1F5F9"/>
				</Trigger>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#F8FAFC"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style TargetType="DataGrid" x:Key="ModernDataGrid">
			<Setter Property="AutoGenerateColumns" Value="False"/>
			<Setter Property="IsReadOnly" Value="True"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="RowHeight" Value="52"/>
			<Setter Property="GridLinesVisibility" Value="None"/>
			<Setter Property="ColumnHeaderStyle" Value="{StaticResource UnifiedHeaderStyle}"/>
			<Setter Property="SelectionMode" Value="Single"/>
		</Style>

		<Style x:Key="ModernButton" TargetType="Button">
			<Setter Property="Background" Value="#2563EB"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Padding" Value="15,8"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="true">
								<Setter TargetName="border" Property="Opacity" Value="0.85"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="true">
								<Setter TargetName="border" Property="RenderTransform">
									<Setter.Value>
										<ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
									</Setter.Value>
								</Setter>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style TargetType="TextBox" x:Key="ModernTextBox">
			<Setter Property="Background" Value="White"/>
			<Setter Property="BorderBrush" Value="#E2E8F0"/>
			<Setter Property="BorderThickness" Value="1.5"/>
			<Setter Property="Padding" Value="12,8"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border x:Name="border" Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
							<ScrollViewer x:Name="PART_ContentHost" Focusable="false"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsFocused" Value="true">
								<Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</UserControl.Resources>

	<Grid Margin="30">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Grid Grid.Row="0" Margin="0,0,0,30">
			<StackPanel HorizontalAlignment="Right">
				<TextBlock x:Name="txtHeaderName" Text="كشف الحساب" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
				<StackPanel Orientation="Horizontal" Margin="0,15,0,0">
					<Border Background="White" CornerRadius="16" Padding="25,15" Margin="0,0,15,0" BorderBrush="#E2E8F0" BorderThickness="1">
						<Border.Effect>
							<DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2"/>
						</Border.Effect>
						<StackPanel>
							<TextBlock Text="صافي المطلوب (دينار)" FontSize="12" Foreground="#64748B" FontWeight="Bold"/>
							<TextBlock x:Name="lblDebtIQD" Text="0 د.ع" FontSize="22" FontWeight="ExtraBold" Foreground="#2563EB" Margin="0,5,0,0"/>
						</StackPanel>
					</Border>
					<Border Background="White" CornerRadius="16" Padding="25,15" BorderBrush="#E2E8F0" BorderThickness="1">
						<Border.Effect>
							<DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2"/>
						</Border.Effect>
						<StackPanel>
							<TextBlock Text="صافي المطلوب (دولار)" FontSize="12" Foreground="#64748B" FontWeight="Bold"/>
							<TextBlock x:Name="lblDebtUSD" Text="$ 0.00" FontSize="22" FontWeight="ExtraBold" Foreground="#059669" Margin="0,5,0,0"/>
						</StackPanel>
					</Border>
				</StackPanel>
			</StackPanel>

			<StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left">
				<Button Click="OpenPayment_Click" Content="تسديد دفعة $" Style="{StaticResource ModernButton}" Background="#EF4444" Height="50" Width="150" Margin="10,0"/>
				<Button Click="ViewLogs_Click" Content="سجل الحركات" Style="{StaticResource ModernButton}" Background="#64748B" Height="50" Width="130"/>
			</StackPanel>
		</Grid>

		<Border Grid.Row="1" Margin="0,0,0,25" Background="White" CornerRadius="20" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
			<Border.Effect>
				<DropShadowEffect BlurRadius="20" Opacity="0.05" ShadowDepth="5" Color="#64748B"/>
			</Border.Effect>
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<StackPanel Grid.Row="0" Orientation="Horizontal">
					<StackPanel Margin="5,0">
						<TextBlock Text="المادة" FontSize="11" Foreground="#94A3B8" Margin="8,0,0,4" FontWeight="Bold"/>
						<TextBox x:Name="txtInputProduct" Style="{StaticResource ModernTextBox}" Width="280"/>
					</StackPanel>
					<StackPanel Margin="5,0">
						<TextBlock Text="العدد" FontSize="11" Foreground="#94A3B8" Margin="8,0,0,4" FontWeight="Bold"/>
						<TextBox x:Name="txtInputQty" Style="{StaticResource ModernTextBox}" Width="70" Text="1" TextAlignment="Center"/>
					</StackPanel>
					<StackPanel Margin="5,0">
						<TextBlock Text="السعر" FontSize="11" Foreground="#94A3B8" Margin="8,0,0,4" FontWeight="Bold"/>
						<TextBox x:Name="txtInputPrice" Style="{StaticResource ModernTextBox}" Width="160" TextChanged="txtInputPrice_TextChanged"/>
					</StackPanel>
					<StackPanel Margin="5,0">
						<TextBlock Text="العملة" FontSize="11" Foreground="#94A3B8" Margin="8,0,0,4" FontWeight="Bold"/>
						<ToggleButton x:Name="btnCurrencyToggle" Width="110" Height="42" Click="Currency_Changed" Cursor="Hand">
							<ToggleButton.Template>
								<ControlTemplate TargetType="ToggleButton">
									<Border x:Name="btnBorder" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="10">
										<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsChecked" Value="True">
											<Setter TargetName="btnBorder" Property="BorderBrush" Value="#3B82F6"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</ToggleButton.Template>
							<StackPanel Orientation="Horizontal">
								<TextBlock x:Name="txtCurrencyFlag" Text="🇮🇶" Margin="0,0,8,0" FontSize="16"/>
								<TextBlock x:Name="txtCurrencyName" Text="د.عراقي" FontWeight="Bold" Foreground="#475569"/>
							</StackPanel>
						</ToggleButton>
					</StackPanel>
					<Button Click="AddItem_Click" Content="+" Style="{StaticResource ModernButton}" Width="60" Height="42" Margin="10,18,0,0" FontSize="24"/>
				</StackPanel>
				<TextBlock Grid.Row="1" x:Name="lblPriceInWords" Text="صفر دينار عراقي" Margin="12,15,0,0" Foreground="#2563EB" FontSize="14" FontWeight="Bold"/>
			</Grid>
		</Border>

		<Border Grid.Row="2" Background="White" CornerRadius="20" ClipToBounds="True" BorderBrush="#E2E8F0" BorderThickness="1">
			<DataGrid x:Name="dgvItems" Style="{StaticResource ModernDataGrid}">
				<DataGrid.Columns>
					<DataGridTextColumn Header="المادة" Binding="{Binding ItemName}" Width="2*" ElementStyle="{StaticResource CenterTextStyle}"/>
					<DataGridTextColumn Header="العدد" Binding="{Binding Quantity}" Width="*" ElementStyle="{StaticResource CenterTextStyle}"/>
					<DataGridTextColumn Header="السعر" Binding="{Binding Price, StringFormat='{}{0:N0}'}" Width="*" ElementStyle="{StaticResource CenterTextStyle}"/>
					<DataGridTextColumn Header="الإجمالي" Binding="{Binding DisplayTotal}" Width="*" >
						<DataGridTextColumn.ElementStyle>
							<Style TargetType="TextBlock" BasedOn="{StaticResource CenterTextStyle}">
								<Setter Property="FontWeight" Value="Bold"/>
								<Setter Property="Foreground" Value="#059669"/>

								<Style.Triggers>
									<DataTrigger Binding="{Binding RemainingTotal}" Value="0">
										<Setter Property="Foreground" Value="#94A3B8"/>
										<Setter Property="TextDecorations" Value="Strikethrough"/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</DataGridTextColumn.ElementStyle>
					</DataGridTextColumn>
					<DataGridTemplateColumn Width="150">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate>
								<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
									<Button Content="تعديل" Click="Edit_Click" Foreground="#4F46E5" Background="Transparent" BorderThickness="0" FontWeight="Bold" Margin="8,0" Cursor="Hand"/>
									<Button Content="حذف" Click="Delete_Click" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontWeight="Bold" Margin="8,0" Cursor="Hand"/>
								</StackPanel>
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>
				</DataGrid.Columns>
			</DataGrid>
		</Border>

		<Grid x:Name="gridPaymentOverlay" Grid.RowSpan="3" Background="#B30F172A" Visibility="Collapsed" Margin="-30">
			<Border Background="White" CornerRadius="30" Width="480" Height="Auto" VerticalAlignment="Center" Padding="40">
				<Border.Effect>
					<DropShadowEffect BlurRadius="50" Opacity="0.4" ShadowDepth="0"/>
				</Border.Effect>
				<StackPanel>
					<TextBlock Text="💸 تسجيل عملية تسديد" FontSize="24" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,30"/>

					<TextBlock Text="المدفوع من قبل:" FontSize="11" Foreground="#94A3B8" Margin="8,0,0,5" FontWeight="Bold"/>
					<TextBox x:Name="txtPaymentDebtorName" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Background="#F8FAFC" Margin="0,0,0,20"/>

					<TextBlock Text="المبلغ المسدد:" FontSize="11" Foreground="#94A3B8" Margin="8,0,0,5" FontWeight="Bold"/>
					<TextBox x:Name="txtPaymentAmount"
							 Style="{StaticResource ModernTextBox}"
							 FontSize="22" FontWeight="Bold"
							 Foreground="#EF4444"
							 Margin="0,0,0,5"
							 TextChanged="txtPaymentAmount_TextChanged"/>

					<TextBlock x:Name="lblPaymentAmountInWords"
							   Text="صفر دينار عراقي"
							   FontSize="13" FontWeight="Bold"
							   Foreground="#2563EB"
							   Margin="10,0,0,20"
							   TextWrapping="Wrap"/>

					<TextBlock Text="اختر العملة:" FontSize="11" Foreground="#94A3B8" Margin="8,0,0,5" FontWeight="Bold"/>
					<ToggleButton x:Name="btnPaymentCurrencyToggle" Height="50" Margin="0,0,0,35" Click="PaymentCurrency_Changed">
						<ToggleButton.Template>
							<ControlTemplate TargetType="ToggleButton">
								<Border x:Name="border" Background="#F1F5F9" CornerRadius="12">
									<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsChecked" Value="True">
										<Setter TargetName="border" Property="Background" Value="#DCFCE7"/>
										<Setter TargetName="border" Property="BorderBrush" Value="#22C55E"/>
										<Setter TargetName="border" Property="BorderThickness" Value="1"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</ToggleButton.Template>
						<StackPanel Orientation="Horizontal">
							<TextBlock x:Name="txtPayCurrencyFlag" Text="🇮🇶" Margin="0,0,10,0" FontSize="20"/>
							<TextBlock x:Name="txtPayCurrencyName" Text="دينار عراقي" FontWeight="Bold" FontSize="15" Foreground="#1E293B"/>
						</StackPanel>
					</ToggleButton>

					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<Button Click="ConfirmPayment_Click" Content="تأكيد العملية" Style="{StaticResource ModernButton}" Grid.Column="0" Height="55" Margin="0,0,8,0" Background="#10B981"/>
						<Button Click="ClosePayment_Click" Content="إلغاء" Style="{StaticResource ModernButton}" Grid.Column="1" Height="55" Background="#F1F5F9" Foreground="#64748B"/>
					</Grid>
				</StackPanel>
			</Border>
		</Grid>

		<Grid x:Name="gridLogsOverlay" Grid.RowSpan="3" Background="#B30F172A" Visibility="Collapsed" Margin="-30">
			<Border Background="White" CornerRadius="25" Width="800" Height="600" VerticalAlignment="Center" Padding="30">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>
					<DockPanel Grid.Row="0" Margin="0,0,0,25">
						<Button Content="✕" Click="CloseLogs_Click" Background="Transparent" BorderThickness="0" FontSize="22" Foreground="#94A3B8" Cursor="Hand" DockPanel.Dock="Left"/>
						<TextBlock Text="📜 تاريخ العمليات" FontSize="22" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
					</DockPanel>
					<DataGrid x:Name="dgvLogs" Grid.Row="1" Style="{StaticResource ModernDataGrid}">
						<DataGrid.Columns>
							<DataGridTextColumn Header="التاريخ والوقت" Binding="{Binding LogDate}" Width="180" ElementStyle="{StaticResource CenterTextStyle}"/>
							<DataGridTextColumn Header="العملية" Binding="{Binding ActionType}" Width="100" FontWeight="Bold" ElementStyle="{StaticResource CenterTextStyle}"/>
							<DataGridTextColumn Header="التفاصيل كاملة" Binding="{Binding Details}" Width="*" ElementStyle="{StaticResource CenterTextStyle}"/>
						</DataGrid.Columns>
					</DataGrid>
					<Button Grid.Row="2" Content="إغلاق السجل" Click="CloseLogs_Click" Style="{StaticResource ModernButton}" Background="#F1F5F9" Foreground="#64748B" Height="50" Margin="0,20,0,0"/>
				</Grid>
			</Border>
		</Grid>
	</Grid>
</UserControl>