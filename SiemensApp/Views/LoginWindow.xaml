<Window x:Class="SiemensApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Siemens Login" Height="450" Width="400"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVis"/>
		<Storyboard x:Key="ShakeAnimation">
			<DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" Storyboard.TargetName="MainBorder">
				<EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
				<EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="-15"/>
				<EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="15"/>
				<EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="-15"/>
				<EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="0"/>
			</DoubleAnimationUsingKeyFrames>
		</Storyboard>
	</Window.Resources>

	<Border x:Name="MainBorder" CornerRadius="30" BorderThickness="1" BorderBrush="#334155" SnapsToDevicePixels="True">
		<Border.RenderTransform>
			<TranslateTransform X="0"/>
		</Border.RenderTransform>

		<Border.Background>
			<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
				<GradientStop Color="#001F2C" Offset="0"/>
				<GradientStop Color="#004655" Offset="1"/>
			</LinearGradientBrush>
		</Border.Background>

		<Grid Margin="35">
			<StackPanel VerticalAlignment="Center">
				<TextBlock Text="🔒" FontSize="45" HorizontalAlignment="Center" Margin="0,0,0,15"/>

				<TextBlock Text="SIEMENS" FontSize="35" FontWeight="ExtraBold" Foreground="#00FFD1"
                           HorizontalAlignment="Center" FontFamily="Arial Black" Margin="0,0,0,45"/>

				<!-- حقل الباسورد بتصميم أنعم -->
				<Border CornerRadius="10" Background="#1A000000" BorderBrush="#3300FFD1" BorderThickness="1">
					<PasswordBox x:Name="txtPassword" Height="50" FontSize="26"
                                 Background="Transparent" Foreground="White" BorderThickness="0"
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                 PasswordChanged="OnPasswordChanged"/>
				</Border>

				<!-- رسالة الخطأ المرئية فقط عند الفشل -->
				<TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B" FontSize="13" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,15,0,0" TextWrapping="Wrap" TextAlignment="Center"
                           Visibility="{Binding IsErrorVisible, Converter={StaticResource BoolToVis}}"/>

				<!-- زر فتح البرنامج: من تركوازي إلى تركوازي غامق -->
				<Button Content="فـتـح الـنـظـام" IsDefault="True" Command="{Binding LoginCommand}" Height="55" Margin="0,30,0,0"
                        Cursor="Hand" BorderThickness="0" FontWeight="Bold" FontSize="17">
					<Button.Style>
						<Style TargetType="Button">
							<Setter Property="Background" Value="#00FFD1"/>
							<Setter Property="Foreground" Value="#001F2C"/>
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="Button">
										<Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="12">
											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger Property="IsMouseOver" Value="True">
												<!-- هنا التغيير: يصير أطوخ مو أبيض -->
												<Setter TargetName="btnBorder" Property="Background" Value="#00D1AB"/>
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</Button.Style>
				</Button>

				<!-- زر الإغلاق: شفاف ويتحول لأحمر هادئ عند التحديد -->
				<Button Content="إغلاق" Command="{Binding ExitCommand}" Height="40" Margin="0,15,0,0"
                        Cursor="Hand" BorderThickness="1" FontSize="14">
					<Button.Style>
						<Style TargetType="Button">
							<Setter Property="Background" Value="Transparent"/>
							<Setter Property="Foreground" Value="#94A3B8"/>
							<Setter Property="BorderBrush" Value="#3394A3B8"/>
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="Button">
										<Border x:Name="exitBorder" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger Property="IsMouseOver" Value="True">
												<Setter TargetName="exitBorder" Property="Background" Value="#CCFF4444"/>
												<Setter TargetName="exitBorder" Property="BorderBrush" Value="#FF4444"/>
												<Setter Property="Foreground" Value="White"/>
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</Button.Style>
				</Button>
			</StackPanel>
		</Grid>
	</Border>
</Window>