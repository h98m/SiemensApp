<UserControl x:Class="SiemensApp.Views.AddProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC" FlowDirection="RightToLeft">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="15" Padding="20" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Border Background="#F1F5F9" CornerRadius="10" Padding="10,2" Width="250" Margin="0,0,15,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="#94A3B8"/>
                            <TextBox x:Name="txtSearch" Grid.Column="1" Background="Transparent" BorderThickness="0" 
                                     Height="35" VerticalContentAlignment="Center" TextChanged="txtSearch_TextChanged"/>
                        </Grid>
                    </Border>

                    <Button Content="+ إضافة منتج جديد" Click="ShowAddCard_Click" Background="#005F73" Foreground="White" 
                            Padding="15,0" Height="40" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="15" Padding="10">
            <DataGrid x:Name="dgvAddedItems"  AutoGenerateColumns="False" 
  IsReadOnly="True" 
  GridLinesVisibility="None" 
  HeadersVisibility="Column"
  Background="Transparent" 
  BorderThickness="0"
  RowHeight="60" 
  AlternatingRowBackground="#F8FAFC"
  FontSize="15">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="15,12"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>

                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#005F73"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="الباركود" Binding="{Binding Barcode}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="15,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="الاسم" Binding="{Binding BrandName}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="15,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="المادة" Binding="{Binding ProductName}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="15,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="السعر" Binding="{Binding DisplayPrice}" IsReadOnly="True" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Currency}" Value="USD">
                                        <Setter Property="Foreground" Value="Green"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Currency}" Value="#005F73"/>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="العدد" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="10,5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Quantity}" FontWeight="ExtraBold" Foreground="#0F172A"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="الإجراءات" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="تعديل" Click="BtnEdit_Click" Foreground="#0284C7" Background="Transparent" BorderThickness="0" FontWeight="Bold" Margin="5,0"/>
                                    <Button Content="حذف" Click="BtnDelete_Click" Foreground="#E11D48" Background="Transparent" BorderThickness="0" FontWeight="Bold" Margin="5,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid x:Name="AddProductCard" Grid.RowSpan="3" Visibility="Collapsed">
            <Grid.Background>
                <SolidColorBrush Color="Black" Opacity="0.4"/>
            </Grid.Background>

            <Border Background="White" 
            CornerRadius="24" 
            Width="480" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center"
            Padding="40"
            BorderBrush="#E2E8F0"
            BorderThickness="1">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" Color="#000000" Opacity="0.15" ShadowDepth="10" Direction="270"/>
                </Border.Effect>

                <StackPanel>
                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="إضافة منتج جديد" 
                           FontSize="24" 
                           FontWeight="ExtraBold" 
                           Foreground="#0F172A" 
                           HorizontalAlignment="Left"/>
                        <Rectangle Height="4" Width="40" Fill="#005F73" HorizontalAlignment="Left" Margin="2,8,0,0" RadiusX="2" RadiusY="2"/>
                    </StackPanel>

                    <TextBlock Text="الباركود الرقمي" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#475569" FontSize="13"/>
                    <TextBox x:Name="txtBarcode" Height="45" Padding="10,8" VerticalContentAlignment="Center" Background="#F8FAFC" BorderBrush="#E2E8F0" Margin="0,0,0,15"/>

                    <TextBlock Text="رمز المنتج" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#475569" FontSize="13"/>
                    <TextBox x:Name="txtBrand" Height="45" Padding="10,8" VerticalContentAlignment="Center" Background="#F8FAFC" BorderBrush="#E2E8F0" Margin="0,0,0,15"/>

                    <TextBlock Text="اسم المنتج" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#475569" FontSize="13"/>
                    <TextBox x:Name="txtProductName" Height="45" Padding="10,8" VerticalContentAlignment="Center" Background="#F8FAFC" BorderBrush="#E2E8F0" Margin="0,0,0,15"/>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="العدد" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#475569" FontSize="13"/>
                            <TextBox x:Name="txtQuantity" Height="45" Padding="10,8" VerticalContentAlignment="Center" Background="#F8FAFC" BorderBrush="#E2E8F0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Grid>
                                <TextBlock Text="السعر" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#475569" FontSize="13" HorizontalAlignment="Left"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <RadioButton x:Name="rbIQD" Content="دينار" IsChecked="True" GroupName="Currency" Tag="IQD" FontSize="11" Foreground="#64748B" Margin="0,0,10,0"/>
                                    <RadioButton x:Name="rbUSD" Content="دولار" GroupName="Currency" Tag="USD" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <TextBox x:Name="txtPrice" Height="45" Padding="10,8,45,8" VerticalContentAlignment="Center" 
                                 FontWeight="Bold" Foreground="#005F73" Background="#F8FAFC" BorderBrush="#E2E8F0"/>
                                <TextBlock Text="IQD/$" Foreground="#94A3B8" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0" IsHitTestVisible="False"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,35,0,0">
                        <Button x:Name="btnSaveAction" Content="حفظ المنتج" Click="BtnSave_Click" Width="260" Height="50" Background="#005F73" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,15,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="12"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Content="إلغاء" Click="HideAddCard_Click" Width="125" Height="50" Background="Transparent" Foreground="#64748B" BorderBrush="#E2E8F0" FontSize="14" FontWeight="Medium">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="12"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>